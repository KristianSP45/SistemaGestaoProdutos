<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ConsultarActivity">

    <TextView
        android:id="@+id/txtTituloConsultar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Consultar Produtos"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="80dp"/>

    <EditText
        android:id="@+id/edIdProduto"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:hint="ID"
        android:enabled="false"
        app:layout_constraintTop_toBottomOf="@id/txtTituloConsultar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <EditText
        android:id="@+id/edNomeProduto"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:hint="Nome Produto"
        android:enabled="false"
        app:layout_constraintTop_toBottomOf="@id/edIdProduto"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <EditText
        android:id="@+id/edValorProduto"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:hint="Valor Produto"
        android:enabled="false"
        app:layout_constraintTop_toBottomOf="@id/edNomeProduto"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <EditText
        android:id="@+id/edQuantidadeProduto"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:hint="Quantidade"
        android:enabled="false"
        app:layout_constraintTop_toBottomOf="@id/edValorProduto"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <LinearLayout
        android:id="@+id/layoutBotoes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="15dp"
        app:layout_constraintTop_toBottomOf="@id/edQuantidadeProduto"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp">

        <ImageView
            android:id="@+id/imgPrimeiro"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:contentDescription="Primeiro"
            android:scaleType="fitXY"
            android:src="@drawable/botao_primeiro" />

        <ImageView
            android:id="@+id/imgAnterior"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:contentDescription="Anterior"
            android:scaleType="fitXY"
            android:src="@drawable/botao_anterior" />

        <ImageView
            android:id="@+id/imgProximo"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:contentDescription="Próximo"
            android:scaleType="fitXY"
            android:src="@drawable/botao_proximo" />

        <ImageView
            android:id="@+id/imgUltimo"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:contentDescription="Último"
            android:scaleType="fitXY"
            android:src="@drawable/botao_ultimo" />

    </LinearLayout>

    <Button
        android:id="@+id/btnVoltar"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:text="Voltar"
        app:layout_constraintTop_toBottomOf="@id/layoutBotoes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>